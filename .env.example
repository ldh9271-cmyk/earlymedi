# ─────────────────────────────────────────────────────────
# KoreaGlowUp AI Concierge — Environment Variables
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="KoreaGlowUp AI Concierge"
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ── Database (Drizzle direct) ────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/earlymedi
# Connection pooler (transaction mode) — for serverless runtimes
DATABASE_POOL_URL=postgresql://postgres:password@localhost:6543/earlymedi

# ── Encryption (pgcrypto) ────────────────────────────────
PII_ENCRYPTION_KEY=replace_with_32_byte_random_hex
INVITE_TOKEN_SECRET=replace_with_strong_random_secret

# ── Master / Platform Admin ──────────────────────────────
# Comma-separated emails that can impersonate ANY organization (owner
# privileges on every tenant). Used by support / founder accounts to
# debug customer issues. Every master action is still audited.
# Leave EMPTY in production unless you really need it.
MASTER_EMAILS=

# ── AI Providers ─────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./.gcp-service-account.json

# AI model defaults (fallback chain)
AI_PRIMARY_MODEL=gemini-2.5-pro
AI_FALLBACK_MODEL=claude-opus-4-7
AI_VISION_MODEL=gemini-2.5-pro
AI_STT_MODEL=whisper-1

# ── Payments ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=

WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

WISE_API_TOKEN=

# ── Messaging ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@koreaglowup.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ── Channel Integrations ─────────────────────────────────
KAKAO_REST_API_KEY=
KAKAO_CHANNEL_PUBLIC_ID=

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_PAGE_TOKEN=

LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

WHATSAPP_BUSINESS_TOKEN=

WECHAT_OFFICIAL_TOKEN=

TELEGRAM_BOT_TOKEN=

# ── Maps ─────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Scheduler ────────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Video Re-consultation ────────────────────────────────
DAILY_API_KEY=
ZOOM_API_KEY=
ZOOM_API_SECRET=

# ── FX Rates ─────────────────────────────────────────────
FX_API_KEY=
FX_PROVIDER=exchangerate-api

# ── Observability ────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
LOG_LEVEL=info

# ── Feature flags ────────────────────────────────────────
FEATURE_AI_AUTOFILL=true
FEATURE_RECOVERY_PHOTO_ANALYSIS=true
FEATURE_WHITELABEL=false
